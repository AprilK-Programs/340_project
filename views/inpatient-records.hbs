<h2>Update a Record</h2>
<form class='cuForm' id='update_record_form' method ='POST' action ='/inpatient-records/update'>
    <label for='update_record_id'>Record to Update: </label>
    <select name='update_record_id' id='update_record_id' required>
        <option value='NULL' selected>Select a Record</option>
        {{#each record}}
        <option value='{{this.[inPatient ID]}}' required>
            {{this.[inPatient ID]}}
        </option>
        {{/each}}
    </select>

    <label for='update_record_trainer'>Trainer: </label>
    <select name='update_record_trainer' id='update_record_trainer'>
        <option value='NULL' selected>Select a Trainer</option>
        {{#each trainer}}
        <option value='{{this.trainerID}}' required>
            {{this.trainerID}}
            -
            {{this.trainerFirstName}}
            {{this.trainerLastName}}
        </option>
        {{/each}}
    </select>

    <label for='update_record_pokemon'>Pokemon: </label>
    <select name='update_record_pokemon' id='update_record_pokemon'>
        <option value='NULL' selected>Select a Pokemon</option>
        {{#each pokemon}}
        <option value='{{this.pokemonID}}' required>
            {{this.pokemonID}}
            -
            {{this.species}}
            {{this.pokemonName}}
        </option>
        {{/each}}
    </select>

    <label for='update_record_center'>PokeCenter: </label>
    <select name='update_record_center' id='update_record_center'>
        <option value='NULL' selected>Select a PokeCenter</option>
        {{#each center}}
        <option value='{{this.centerID}}' required>
            {{this.centerID}}
            -
            {{this.location}}
        </option>
        {{/each}}
    </select>

    <input type='submit' />
</form>


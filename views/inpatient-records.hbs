<h2>Create a Record</h2>
<form class='cuForm' id='create_record_form' method='POST' action='/inpatient-records/create'>
     <label for='create_record_trainer'>Trainer: </label>
     <select name='create_record_trainer' id='create_record_trainer'>
       
        <option value='NULL' selected>Select a Trainer</option>
        {{#each trainer}}
        <option value='{{this.trainerID}}'  required>{{this.trainerID}}          
            -
            {{this.trainerFirstName}}
            {{this.trainerLastName}}
        </option>
        {{/each}}
     </select>

    <label for='create_record_center'>PokeCenter: </label>
    <select name='create_record_center' id='create_record_center'>
        <option value='NULL' selected>Select a PokeCenter</option>
        {{#each center}}
        <option value='{{this.centerID}}' required>{{this.centerID}}
            -
            {{this.location}}
        </option>
        {{/each}}
    </select>

    <label for='create_record_pokemon'>Pokemon: </label>
    <select name='create_record_pokemon' id='create_record_pokemon'>
        <option value='NULL' selected>Select a Pokemon</option>
        {{#each pokemon}}
        <option value='{{this.pokemonID}}' required>{{this.pokemonID}}
            -
            {{this.species}}
            {{this.pokemonName}}

        </option>
        {{/each}}
    </select>

    <input type='submit' />
</form>


<h1>InPatient Records</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            {{#each record.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
            <th></th>
           
        </tr>
    </thead>

    <tbody>
        {{! For each row, print the id, fname, lname, homeworld and age }}
        {{#each record}}
        <tr>
            <td>{{this.[inPatient ID]}}</td>
            <td>{{this.[Trainer Name]}}</td>
            <td>{{this.[Pokemon Name]}}</td>
            <td>{{this.[Pokecenter Location]}}</td>
            {{! DELETE form }}
            <form id='delete_record_form' method ='POST' action ='/inpatient-records/delete'>
                <input type='hidden' name='delete_record_id' value='{{this.[inPatient ID]}}' />
                <input type='hidden' name='delete_record_name' value='{{this.[Trainer Name]}}' /> 
                <td>
                    <button type='submit'>
                        Delete
                    </button>
                </td>
            </form>
        </tr>       
        {{/each}}

    </tbody>
</table>
{{! CREATE form }}
